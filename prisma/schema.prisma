// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// Note: connection URL is provided at runtime via the pg adapter (src/lib/prisma.ts).
// Prisma Migrate reads DATABASE_URL / DIRECT_URL from prisma.config.ts.

model User {
  id          String   @id @default(cuid())
  email       String   @unique
  name        String?
  password    String
  timezone    String   @default("UTC")
  // Opt-in: user's Gemini API key, encrypted at rest (AES-256-GCM). Enables
  // server-side features (scheduled messages, background summaries). Null = the
  // key stays client-side only (default BYOK behavior).
  geminiKeyEnc String?
  // learning prefs
  maxNewWords Int      @default(1)
  level       String   @default("N5")
  // ── Kai outreach ("messages first") ──
  outreachMode      String   @default("off") // off | scheduled | random
  outreachTimes     String   @default("[]")  // JSON "HH:MM"[] for scheduled mode
  quietStart        Int      @default(22)     // hour (0-23) — no pings at/after
  quietEnd          Int      @default(8)      // hour (0-23) — no pings before
  consecutiveIgnored Int     @default(0)      // outreach streak with no return
  lastOutreachAt    DateTime?                  // when Kai last reached out
  lastActiveAt      DateTime?                  // when the user last chatted/opened
  // ── Streak ──
  streakCount    Int     @default(0)  // consecutive active days
  streakBestCount Int    @default(0)  // longest streak achieved
  lastStreakDay  String?              // dayKey of the last counted active day
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  messages     Message[]
  flashcards   Flashcard[]
  daySummaries DaySummary[]
  memories     Memory[]
  kanjiMnemonics KanjiMnemonic[]
  userKanji    UserKanji[]

  // ── Social: friends, groups, personas ──
  personas        Persona[]
  ownedGroups     Group[]          @relation("GroupOwner")
  groupMemberships GroupMember[]
  groupMessages   GroupMessage[]
  friendRequestsSent     Friendship[] @relation("FriendRequester")
  friendRequestsReceived Friendship[] @relation("FriendAddressee")
}

// A reusable AI character. Kai ships as a built-in (seeded with a null userId);
// users can also create their own personas to drop into group chats.
model Persona {
  id          String  @id @default(cuid())
  // Null userId = built-in/global persona (e.g. Kai). Otherwise the creator.
  userId      String?
  user        User?   @relation(fields: [userId], references: [id], onDelete: Cascade)

  name        String
  // Short tagline shown in pickers, e.g. "Cheerful Japanese tutor".
  blurb       String  @default("")
  // The persona's voice/role — injected into the system prompt.
  personality String
  avatar      String  @default("🤖") // emoji avatar for now
  builtin     Boolean @default(false)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  groupMembers GroupMember[]
  memories     Memory[]

  @@index([userId])
}

// Symmetric friendship modeled as a directed request that gets accepted.
model Friendship {
  id          String @id @default(cuid())
  requesterId String
  requester   User   @relation("FriendRequester", fields: [requesterId], references: [id], onDelete: Cascade)
  addresseeId String
  addressee   User   @relation("FriendAddressee", fields: [addresseeId], references: [id], onDelete: Cascade)

  status      String @default("pending") // pending | accepted

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([requesterId, addresseeId])
  @@index([addresseeId, status])
  @@index([requesterId, status])
}

// A conversation. `kind` distinguishes a 1:1 persona chat, a user↔user DM, and
// a multi-person group. AI-containing conversations get the rich learning
// features (tokens/english/correction). The owner provides the API key.
model Group {
  id          String @id @default(cuid())
  name        String
  kind        String @default("group") // "persona" | "dm" | "group"
  ownerId     String
  owner       User   @relation("GroupOwner", fields: [ownerId], references: [id], onDelete: Cascade)

  // Owner's Gemini key(s) for this conversation, encrypted at rest
  // (AES-256-GCM). JSON array of keys. Null = no AI replies.
  apiKeyEnc   String?

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  members  GroupMember[]
  messages GroupMessage[]

  @@index([ownerId])
}

// A participant in a group: either a human user OR an AI persona.
model GroupMember {
  id        String @id @default(cuid())
  groupId   String
  group     Group  @relation(fields: [groupId], references: [id], onDelete: Cascade)

  // Exactly one of userId / personaId is set (kind disambiguates).
  kind      String // "user" | "persona"
  // Invite state for human members. Personas are always "accepted".
  // The group owner is auto-accepted on creation.
  status    String  @default("accepted") // pending | accepted
  userId    String?
  user      User?    @relation(fields: [userId], references: [id], onDelete: Cascade)
  personaId String?
  persona   Persona? @relation(fields: [personaId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  messages GroupMessage[]

  @@unique([groupId, userId])
  @@unique([groupId, personaId])
  @@index([groupId])
}

model GroupMessage {
  id        String @id @default(cuid())
  groupId   String
  group     Group  @relation(fields: [groupId], references: [id], onDelete: Cascade)

  // The author. senderUserId set for humans, senderPersonaId for AI.
  memberId      String?
  member        GroupMember? @relation(fields: [memberId], references: [id], onDelete: SetNull)
  senderUserId  String?
  senderUser    User?        @relation(fields: [senderUserId], references: [id], onDelete: SetNull)
  senderName    String       // denormalized display name (human name or persona name)
  senderKind    String       // "user" | "persona"

  content   String
  // Rich learning fields, populated for AI (persona) messages — same as Kai's
  // 1:1 chat. JSON strings; null for human messages.
  english    String?
  tokens     String?
  correction String?
  createdAt DateTime @default(now())

  @@index([groupId, createdAt])
}

model Message {
  id      String @id @default(cuid())
  userId  String
  user    User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  role    String // "kai" | "user"
  content String

  // Natural English translation/gloss of a Japanese reply (Kai messages).
  english String?

  // Cached tokenization for tap-to-translate (JSON string of CachedToken[]).
  tokens  String?

  // Grammar feedback on the user's Japanese, attached to Kai's reply for that
  // turn (JSON string of Correction). Null when there's nothing to show.
  correction String?

  // Whether this Kai message was sent proactively (Kai messaging first, no
  // preceding user turn) rather than as a direct reply.
  proactive Boolean @default(false)

  // Optional quote-reply: the earlier message this one is replying to.
  replyToId String?
  replyTo   Message?  @relation("MessageReplies", fields: [replyToId], references: [id], onDelete: SetNull)
  replies   Message[] @relation("MessageReplies")

  // Day bucket, computed in the user's tz at insert time, e.g. "2026-06-27".
  dayKey     String
  summarized Boolean @default(false)

  createdAt DateTime @default(now())

  capturedWords Flashcard[] @relation("WordSource")

  @@index([userId, createdAt])
  @@index([userId, dayKey])
  @@index([replyToId])
}

model Flashcard {
  id           String @id @default(cuid())
  userId       String
  user         User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  word         String // dictionary/lemma form — dedupe key
  reading      String
  romaji       String
  meaning      String // primary meaning, or comma-separated meanings
  partOfSpeech String
  jlptTier     String @default("unknown")
  // JSON array of meaning contexts: [{ meaning: "to take", example: "物を取る" }]
  meaningContexts String?

  // SRS (SM-2). status drives usage policy.
  status        String   @default("new") // new | learning | known
  easeFactor    Float    @default(2.5)
  interval      Int      @default(0)
  repetitions   Int      @default(0)
  timesReviewed Int      @default(0)
  exposures     Int      @default(0)
  nextReview    DateTime @default(now())
  lastReviewedAt DateTime?

  sourceMessageId String?
  sourceMessage   Message? @relation("WordSource", fields: [sourceMessageId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, word])
  @@index([userId, status])
  @@index([userId, nextReview])
  @@index([userId, partOfSpeech])
}

model DaySummary {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  dayKey    String
  summary   String
  wordCount Int      @default(0)
  partial   Boolean  @default(false)
  monthKey  String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, dayKey])
  @@index([userId, dayKey])
}

model Memory {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Which persona this memory belongs to (scoped per user). Null = Kai, the
  // default tutor (preserves pre-persona memories without migration).
  personaId  String?
  persona    Persona? @relation(fields: [personaId], references: [id], onDelete: Cascade)

  content    String
  category   String   @default("fact") // profile | preference | fact | goal | relationship
  importance Int      @default(1) // 1..5
  sourceDayKey String?

  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([userId, category])
  @@index([userId, personaId])
}

// User's kanji learning progress with SRS
model UserKanji {
  id            String   @id @default(cuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  kanjiId       String
  kanji         Kanji    @relation(fields: [kanjiId], references: [id], onDelete: Cascade)

  // SRS (SM-2). Same as Flashcard
  status        String   @default("new") // new | learning | known
  easeFactor    Float    @default(2.5)
  interval      Int      @default(0)
  repetitions   Int      @default(0)
  timesReviewed Int      @default(0)
  nextReview    DateTime @default(now())
  lastReviewedAt DateTime?

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([userId, kanjiId])
  @@index([userId, status])
  @@index([userId, nextReview])
}

// Kanji character information seeded from kanji-data.json
model Kanji {
  id            String   @id @default(cuid())
  character     String   @unique  // The kanji itself, e.g., "勝"
  strokes       Int                // Stroke count
  grade         Int?               // School grade level (1-6 for kyouiku)
  frequency     Int?               // Usage frequency rank (lower = more common)
  jlptLevel     Int?               // JLPT level: 5=N5, 4=N4, 3=N3, 2=N2, 1=N1
  meanings      String             // JSON array: ["Victory", "Win"]
  readingsOn    String             // JSON array: ["しょう"]
  readingsKun   String             // JSON array: ["か.つ", "まさ.る"]
  radicals      String             // JSON array: ["Moon", "Gladiator", "Power"]
  wkLevel       Int?               // WaniKani level (1-60)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  mnemonics     KanjiMnemonic[]
  userKanji     UserKanji[]
  
  @@index([jlptLevel])
  @@index([grade])
  @@index([frequency])
  @@index([character])
}

// User-specific AI-generated mnemonics for kanji
model KanjiMnemonic {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  kanjiId    String
  kanji      Kanji    @relation(fields: [kanjiId], references: [id], onDelete: Cascade)
  mnemonic   String   // AI-generated story
  createdAt  DateTime @default(now())
  
  @@unique([userId, kanjiId])
  @@index([userId])
  @@index([kanjiId])
}
