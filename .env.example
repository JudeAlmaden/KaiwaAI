# Copy to .env and fill in. Never commit .env (it's gitignored).

# PostgreSQL (Supabase). Use the POOLED connection string for serverless (Vercel):
# Supabase → Project Settings → Database → Connection string → "Transaction" pooler
# (port 6543). Append ?pgbouncer=true&connection_limit=1 for serverless.
DATABASE_URL="postgresql://postgres:password@localhost:5432/kaiwaai"
# Direct (non-pooled) connection — used by Prisma Migrate (port 5432).
DIRECT_URL="postgresql://postgres:password@localhost:5432/kaiwaai"

# Secret used to sign session cookies. Use a long random string.
SESSION_SECRET="change-me-to-a-long-random-string"

# Key for encrypting secrets at rest (AES-256-GCM). 32 bytes, base64-encoded.
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
ENCRYPTION_KEY="generate-a-32-byte-base64-key"

# Shared secret the scheduler sends as a Bearer token to call trigger endpoints.
TRIGGER_SECRET="change-me"

# Vercel Cron auth — set this in Vercel project settings; Vercel sends it as a
# Bearer token to cron routes automatically.
CRON_SECRET="change-me"
